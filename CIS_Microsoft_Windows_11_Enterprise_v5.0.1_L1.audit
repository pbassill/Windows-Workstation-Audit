      value_type  : POLICY_DWORD
      value_data  : "1"
      reg_key     : "HKLM\Software\Policies\Microsoft\Windows\CloudContent"
      reg_item    : "DisableWindowsConsumerFeatures"
      reg_option  : CAN_NOT_BE_NULL
