      value_type  : POLICY_DWORD
      value_data  : "1"
      reg_key     : "HKLM\Software\Policies\Microsoft\Windows Defender\Windows Defender Exploit Guard\ASR"
      reg_item    : "ExploitGuard_ASR_Rules"
      reg_option  : CAN_NOT_BE_NULL
    </custom_item>

