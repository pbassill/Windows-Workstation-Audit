      see_also    : "https://workbench.cisecurity.org/benchmarks/26296"
      value_type  : POLICY_DWORD
      value_data  : "0"
      reg_key     : "HKLM\Software\Policies\Microsoft\Windows NT\Printers\RPC"
      reg_item    : "RpcUseNamedPipeProtocol"
      reg_option  : CAN_NOT_BE_NULL
    </custom_item>

