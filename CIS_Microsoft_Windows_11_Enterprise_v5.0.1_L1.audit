      see_also    : "https://workbench.cisecurity.org/benchmarks/26296"
      value_type  : POLICY_DWORD
      value_data  : "1"
      reg_key     : "HKLM\Software\Policies\Microsoft\Windows\LanmanServer"
      reg_item    : "AuditClientDoesNotSupportEncryption"
